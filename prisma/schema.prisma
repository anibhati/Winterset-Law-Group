generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  phone               String?
  name                String
  password            String
  role                Role                  @default(CLIENT)
  createdAt           DateTime              @default(now())
  auditLogs           AuditLog[]
  consultations       ConsultationBooking[]
  debtAccount         DebtAccount?
  disputes            DisputeRequest[]
  planRequests        PaymentPlanRequest[]
  passwordResetTokens PasswordResetToken[]
}

model DebtAccount {
  id             String               @id @default(cuid())
  accountNumber  String               @unique
  userId         String?              @unique
  debtorName     String
  last4Ssn       String
  debtType       DebtType
  originalAmount Float
  currentBalance Float
  agency         String
  status         AccountStatus        @default(ACTIVE)
  createdAt      DateTime             @default(now())
  user           User?                @relation(fields: [userId], references: [id])
  planRequests   PaymentPlanRequest[]
}

model PaymentPlanRequest {
  id                String        @id @default(cuid())
  userId            String?
  debtAccountId     String
  frequency         Frequency
  installmentAmount Float
  startDate         DateTime
  status            RequestStatus @default(PENDING)
  staffNotes        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime      @default(now())
  debtAccount       DebtAccount   @relation(fields: [debtAccountId], references: [id])
  user              User?         @relation(fields: [userId], references: [id])
}

model DisputeRequest {
  id            String        @id @default(cuid())
  userId        String?
  accountNumber String
  name          String
  email         String
  phone         String
  reason        DisputeReason
  description   String
  status        RequestStatus @default(PENDING)
  staffNotes    String?
  createdAt     DateTime      @default(now())
  user          User?         @relation(fields: [userId], references: [id])
}

model ConsultationBooking {
  id            String            @id @default(cuid())
  userId        String?
  name          String
  phone         String
  email         String
  topic         ConsultationTopic
  accountNumber String?
  preferredDate DateTime
  timeSlot      String
  notes         String?
  status        BookingStatus     @default(PENDING)
  confirmedBy   String?
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

enum Role {
  CLIENT
  STAFF
  ATTORNEY
}

enum DebtType {
  INCOME_TAX
  BUSINESS_TAX
  SALES_TAX
  WITHHOLDING_TAX
  BWC
  UNEMPLOYMENT
  MEDICAID
  OTHER
}

enum AccountStatus {
  ACTIVE
  IN_PLAN
  RESOLVED
  DISPUTED
}

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DisputeReason {
  WRONG_AMOUNT
  ALREADY_PAID
  NOT_MY_DEBT
  IDENTITY_THEFT
  OTHER
}

enum ConsultationTopic {
  PAYMENT_PLAN
  DISPUTE
  GENERAL_INQUIRY
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
