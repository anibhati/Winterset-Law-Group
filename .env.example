# ═══════════════════════════════════════════════════════════════════════════════
# Winterset Law Group — Environment Variables
# Copy this file to .env.local and fill in all values before running the app.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars   # Generate: openssl rand -base64 32

NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/winterset_law?schema=public

# ─── Stripe (Payment Processing — PCI Compliant) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # Get from: stripe listen --forward-to localhost:3000/api/payment/webhook

# ─── Twilio (SMS) ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+16145551234   # Your Twilio number (must support SMS)

# ─── Email (pick one: Nodemailer via SMTP, or Resend/SendGrid) ───────────────────
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=smtp-user
EMAIL_SERVER_PASSWORD=smtp-password
EMAIL_FROM=noreply@wintersetlawgroup.com

# (Alternative: Resend)
# RESEND_API_KEY=re_...

# ─── Encryption ──────────────────────────────────────────────────────────────────
# For TOTP secrets stored in DB — in production, use KMS/Vault instead of this key
ENCRYPTION_KEY=your-32-byte-hex-encryption-key   # Generate: openssl rand -hex 32
